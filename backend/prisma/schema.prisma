generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Category {
  DSA
  PROJECT
  ML
  CYBER
  ACADEMICS
  OPEN_SOURCE
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  clerkId       String     @unique
  email         String     @unique
  username      String?    @unique
  name          String?
  totalXP       Int        @default(0)
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  lastActiveAt       DateTime?
  codeforcesHandle   String?
  codeforcesLastSync DateTime?
  leetcodeUsername   String?
  leetcodeLastSync   DateTime?
  githubUsername     String?
  githubToken        String?
  githubLastSync     DateTime?
  vitUsername        String?
  vitPasswordEncrypted String?
  vitLastSync        DateTime?
  googleEmail        String?
  googleRefreshToken String?
  googleCalendarId   String?
  googleLastSync     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  activities      Activity[]
  dailyLogs       DailyLog[]
  leetcode        LeetCodeEntry[]
  codeforces      CodeforcesEntry[]
  cgpa            CGPAEntry[]
  subjects        SubjectEntry[]
  projects        ProjectEntry[]
  openSource      OpenSourceEntry[]
  coreCS          CoreCSEntry[]
  nptel           NPTELEntry[]
  aiml            AIMLEntry[]
  cyber           CyberEntry[]
  gate            GATEEntry[]
  gateSyllabusProgress GATESyllabusProgress[]

  research        ResearchEntry[]
  goals           Goal[]
  leetCodeSnapshots LeetCodeSnapshot[]
  gitHubSnapshots   GitHubSnapshot[]
  vitSnapshots      VITSnapshot[]

  xpTransactions  XPTransaction[]
  careerProfile   CareerProfile?

  certificates    Certificate[]

  @@index([clerkId])
}

// ─── Activity ────────────────────────────────────────────────────────────────

model Activity {
  id        String   @id @default(uuid())
  title     String
  category  Category
  hours     Float
  xp        Int
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dailyLogId String?
  dailyLog   DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([dailyLogId])
  @@index([createdAt])
}

// ─── DailyLog ────────────────────────────────────────────────────────────────

model DailyLog {
  id      String   @id @default(uuid())
  date    DateTime
  notes   String?
  totalXP Int      @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activities Activity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// ─── LeetCode Tracker ────────────────────────────────────────────────────────

model LeetCodeEntry {
  id       String   @id @default(uuid())
  date     DateTime @default(now())
  easy     Int      @default(0)
  medium   Int      @default(0)
  hard     Int      @default(0)
  topics   String[]
  notes    String?
  contestName String?
  rating      Int?
  rank        Int?
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─── Codeforces Tracker ──────────────────────────────────────────────────────

model CodeforcesEntry {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  contestName String?
  rating      Int
  rank        Int?
  solved      Int      @default(0)
  notes       String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ─── CGPA Tracker ────────────────────────────────────────────────────────────

model CGPAEntry {
  id       String  @id @default(uuid())
  semester Int
  sgpa     Float
  cgpa     Float
  credits  Int?
  notes    String?
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semester])
  @@index([userId])
}

// ─── Subject Tracker ─────────────────────────────────────────────────────────

model SubjectEntry {
  id       String  @id @default(uuid())
  name     String
  semester Int
  grade    String?
  marks    Float?
  maxMarks Float?
  credits  Int?
  status   String  @default("IN_PROGRESS")
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Project Tracker ─────────────────────────────────────────────────────────

model ProjectEntry {
  id          String    @id @default(uuid())
  title       String
  description String?
  techStack   String[]
  status      String    @default("IN_PROGRESS")
  githubUrl   String?
  liveUrl     String?
  startDate   DateTime?
  endDate     DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  bullets     ProjectBullet[]
  resumeProjects ResumeProject[]

  @@index([userId])
}

model ProjectBullet {
  id          String        @id @default(uuid())
  projectId   String
  project     ProjectEntry  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text        String
  displayOrder Int          @default(0)
  createdAt   DateTime      @default(now())

  @@index([projectId])
}

// ─── Open Source Tracker ─────────────────────────────────────────────────────

model OpenSourceEntry {
  id      String   @id @default(uuid())
  repo    String
  prTitle String
  prUrl   String?
  status  String   @default("OPEN")
  date    DateTime @default(now())
  notes   String?
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Core CS Topic Tracker ───────────────────────────────────────────────────

model CoreCSEntry {
  id         String   @id @default(uuid())
  subject    String
  topic      String
  status     String   @default("NOT_STARTED")
  confidence Int?
  notes      String?
  date       DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── NPTEL Tracker ───────────────────────────────────────────────────────────

model NPTELEntry {
  id          String  @id @default(uuid())
  courseName  String
  platform    String  @default("NPTEL")
  weeks       Int?
  completed   Int?
  score       Float?
  certificate String?
  status      String  @default("IN_PROGRESS")
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── AI/ML Tracker ───────────────────────────────────────────────────────────

model AIMLEntry {
  id        String   @id @default(uuid())
  title     String
  type      String
  framework String?
  status    String   @default("IN_PROGRESS")
  notes     String?
  date      DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Cybersecurity Tracker ───────────────────────────────────────────────────

model CyberEntry {
  id         String   @id @default(uuid())
  title      String
  platform   String?
  type       String
  difficulty String?
  completed  Boolean  @default(false)
  notes      String?
  date       DateTime @default(now())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── GATE CSE Tracker ────────────────────────────────────────────────────────

model GATEEntry {
  id                 String   @id @default(uuid())
  subject            String
  topic              String
  questionsAttempted Int      @default(0)
  correct            Int      @default(0)
  mockScore          Float?
  notes              String?
  date               DateTime @default(now())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── GATE Syllabus Progress ─────────────────────────────────────────────────

model GATESyllabusProgress {
  id         String   @id @default(uuid())
  topicKey   String
  section    String
  topicLabel String
  completed  Boolean  @default(false)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicKey])
  @@index([userId])
}

// ─── Research / Publications ─────────────────────────────────────────────────

model ResearchEntry {
  id      String   @id @default(uuid())
  title   String
  type    String
  authors String?
  venue   String?
  url     String?
  status  String   @default("READING")
  notes   String?
  date    DateTime @default(now())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Goal Tracker ───────────────────────────────────────────────────────────

enum TrackerSource {
  MANUAL
  LEETCODE_SOLVED
  LEETCODE_EASY_SOLVED
  LEETCODE_MEDIUM_SOLVED
  LEETCODE_HARD_SOLVED
  LEETCODE_RATING
  LEETCODE_CONTESTS
  LEETCODE_VELOCITY
  LEETCODE_READINESS
  LEETCODE_MONTHLY_GROWTH
  LEETCODE_HARD_RATIO
  CODEFORCES_RATING
  CODEFORCES_SOLVED
  PROJECTS_COMPLETED
  OPENSOURCE_PRS
  GITHUB_REPOSITORIES
  GITHUB_PROJECTS
  GITHUB_ACTIVITY
  GITHUB_COMMITS
  GITHUB_READINESS
  VIT_CGPA
  VIT_CREDITS
  VIT_ATTENDANCE
  VIT_READINESS

}

model Goal {
  id            String        @id @default(uuid())
  title         String
  target        Float
  current       Float         @default(0)
  unit          String        @default("%")
  trackerSource TrackerSource @default(MANUAL)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── LeetCode Snapshots for velocity/readiness tracking ─────────────────────

model LeetCodeSnapshot {
  id            String   @id @default(uuid())
  userId        String
  totalSolved   Int
  contestRating Int?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

// ─── GitHub Snapshots for velocity/readiness tracking ──────────────────────

model GitHubSnapshot {
  id        String   @id @default(uuid())
  userId    String
  repoCount Int
  stars     Int
  commits   Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

// ─── VIT Snapshots for CGPA/attendance tracking ────────────────────────────

model VITSnapshot {
  id              String   @id @default(uuid())
  userId          String
  cgpa            Float
  creditsEarned   Float
  creditsRequired Float
  attendance      Float?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

// ─── Certificates ────────────────────────────────────────────────────────────

model Certificate {
  id             String   @id @default(uuid())
  name           String
  issuer         String?
  credentialUrl  String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeCertificates ResumeCertificate[]

  @@index([userId])
}

// ─── Career Studio ─────────────────────────────────────────────────────────

model CareerProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String?
  professionalTitle String?
  email             String?
  phone             String?
  location          String?
  website           String?
  linkedin          String?
  github            String?
  leetcode          String?
  codeforces        String?
  portfolio         String?
  bio               String?
  defaultPhotoId    String?
  preferences       Json?     @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  photos CareerPhoto[]
  resumeProfiles ResumeProfile[]

  @@index([userId])
}

model CareerPhoto {
  id              String        @id @default(uuid())
  careerProfileId String
  careerProfile   CareerProfile @relation(fields: [careerProfileId], references: [id], onDelete: Cascade)
  storageKey      String        @unique
  originalUrl     String
  thumbnailUrl    String?
  mimeType        String
  fileSize        Int
  width           Int?
  height          Int?
  fileName        String
  isDefault       Boolean       @default(false)
  createdAt       DateTime      @default(now())

  resumeProfiles ResumeProfile[]

  @@index([careerProfileId])
}

// ─── Resume Profiles ─────────────────────────────────────────────────────────

model ResumeProfile {
  id              String         @id @default(uuid())
  careerProfileId String
  careerProfile   CareerProfile  @relation(fields: [careerProfileId], references: [id], onDelete: Cascade)
  name            String
  targetRole      String
  description     String?
  template        String         @default("modern")
  pageSize        String         @default("a4")
  photoId         String?
  photo           CareerPhoto?   @relation(fields: [photoId], references: [id], onDelete: SetNull)
  summaryStrategy String         @default("manual")
  isDefault       Boolean        @default(false)
  displayOrder    Int            @default(0)
  sectionSettings Json?         @default("{}")
  lastGeneratedAt DateTime?
  version         Int            @default(1)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  resumeProjects         ResumeProject[]
  resumeCertificates     ResumeCertificate[]
  resumeAchievements     ResumeAchievement[]
  aiReviews              AIReview[]
  resumeRevisions        ResumeRevision[]
  activeRevisionId       String?  @unique
  activeRevision         ResumeRevision?  @relation("ActiveRevision", fields: [activeRevisionId], references: [id], onDelete: SetNull)

  @@index([careerProfileId])
}

// ─── Resume Composition ──────────────────────────────────────────────────────

model ResumeProject {
  id                String        @id @default(uuid())
  resumeProfileId   String
  resumeProfile     ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  projectId         String
  project           ProjectEntry  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  displayOrder      Int           @default(0)
  selectedBulletIds Json          @default("[]")

  @@unique([resumeProfileId, projectId])
  @@index([resumeProfileId])
}

model ResumeCertificate {
  id              String        @id @default(uuid())
  resumeProfileId String
  resumeProfile   ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  certificateId   String
  certificate     Certificate   @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  displayOrder    Int           @default(0)

  @@unique([resumeProfileId, certificateId])
  @@index([resumeProfileId])
}

model ResumeAchievement {
  id              String        @id @default(uuid())
  resumeProfileId String
  resumeProfile   ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  achievementKey  String
  displayOrder    Int           @default(0)

  @@unique([resumeProfileId, achievementKey])
  @@index([resumeProfileId])
}

// ─── Career Intelligence ─────────────────────────────────────────────────────

model AIReview {
  id              String   @id @default(uuid())
  resumeProfileId String
  resumeProfile   ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  section         String       // "summary" | "project" | "achievement"
  sectionItemId   String?      // projectId or achievementKey (null for summary)
  action          String       // "rewrite" | "improve" | "quantify" | "ats-optimize"
  before          Json         // Original content
  after           Json         // AI-suggested content
  edited          Json?        // User-edited version (if different from after)
  reasoning       String[]
  confidence      Float?
  latencyMs       Int?
  tokens          Int?
  status          String   @default("pending")  // pending | accepted | rejected
  promptId        String?      // e.g. "rewrite-summary-v1"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([resumeProfileId])
}

model ResumeRevision {
  id              String       @id @default(uuid())
  resumeProfileId String
  resumeProfile   ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  parentRevisionId String?
  parentRevision   ResumeRevision? @relation("RevisionChain", fields: [parentRevisionId], references: [id])
  children         ResumeRevision[] @relation("RevisionChain")
  label            String?     // e.g. "AI Rewrite: Summary"
  createdAt        DateTime   @default(now())

  changes          ResumeChange[]
  activeProfile    ResumeProfile? @relation("ActiveRevision")

  @@index([resumeProfileId])
}

model ResumeChange {
  id              String         @id @default(uuid())
  revisionId      String
  revision        ResumeRevision @relation(fields: [revisionId], references: [id], onDelete: Cascade)
  section         String         // "summary" | "projects" | "achievements"
  sectionItemId   String?        // projectId or achievementKey (null for summary)
  changeType      String         // "replace" | "modify_bullets" | "modify_description"
  payload         Json           // The actual changes

  @@index([revisionId])
}

// ─── XPTransaction ───────────────────────────────────────────────────────────

model XPTransaction {
  id              String   @id @default(uuid())
  amount          Int      // positive = earned, negative = deducted
  source          String   // ACTIVITY | LEETCODE | GOAL_COMPLETE | ATTENDANCE | FOCUS_SESSION
  sourceId        String?  // Activity.id, etc.
  description     String?
  category        String?  // DSA | ML | PROJECT | ACADEMICS | CYBER | OPEN_SOURCE

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([source, sourceId])
}
