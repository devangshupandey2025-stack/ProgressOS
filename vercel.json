{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/u/(.*)", "destination": "/u.html" },
    { "source": "/career-studio", "destination": "/career-studio/index.html" },
    { "source": "/career-studio/(.*)", "destination": "/career-studio/$1" },
    { "source": "/", "destination": "/landing.html" }
  ]
}
