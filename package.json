{
  "name": "progressos",
  "version": "1.0.0",
  "description": "ProgressOS Full Stack",
  "main": "backend/dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch backend/src/index.ts",
    "build:local": "npx tsc -p backend/tsconfig.json",
    "start": "node backend/dist/index.js",
    "vercel-build": "npm run prisma:generate",
    "prisma:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=backend/prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=backend/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=backend/prisma/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@clerk/express": "^2.1.26",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "@vercel/node": "^3.0.0"
  }
}
